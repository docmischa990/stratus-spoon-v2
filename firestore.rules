rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followerCount', 'followingCount', 'updatedAt']));
      allow delete: if isOwner(userId);

      match /favorites/{recipeId} {
        allow read, write: if isOwner(userId);
      }

      match /collections/{collectionId} {
        allow read, write: if isOwner(userId);

        match /recipes/{recipeId} {
          allow read, write: if isOwner(userId);
        }
      }

      match /ratings/{recipeId} {
        allow read, write: if isOwner(userId);
      }

      match /behaviour/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /pantry/{ingredientId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /followers/{followerId} {
        allow read: if true;
        allow write: if isOwner(followerId);
      }

      match /following/{followingId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    match /recipes/{recipeId} {
      allow read: if resource.data.visibility == 'public' || isOwner(resource.data.ownerId);
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.sourceType == 'internal';
      allow update: if isOwner(resource.data.ownerId)
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.sourceType == resource.data.sourceType;
      allow delete: if isOwner(resource.data.ownerId);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text.size() <= 500;
        allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
        allow update: if false;
      }
    }

    // recipeStats: public read, authenticated write (increments only).
    // Delete is intentionally not allowed — stats are append-only counters.
    match /recipeStats/{recipeId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['viewCount', 'likeCount', 'dislikeCount', 'favoriteCount', 'importCount', 'updatedAt']);
      allow delete: if false;
    }
  }
}
